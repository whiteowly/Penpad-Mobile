rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // usernames mapping: usernames/{normalizedUsername} -> { uid, createdAt }
    match /usernames/{username} {
      // allow authenticated clients to read a single username doc
      allow get, list: if false;

      // Creating a username mapping is allowed only when the caller is the
      // same user as the uid stored in the document.
      allow create: if request.auth != null
                      && request.auth.uid == request.resource.data.uid;

      // Allow deletion only by the original reserver
      allow delete: if request.auth != null
                      && resource.data.uid == request.auth.uid;

      // Prevent client-side updates
      allow update: if false;
    }

    // Incoming friend requests live at: users/{userId}/friendRequests/{requestId}
    match /users/{userId}/friendRequests/{requestId} {
      // Only the recipient (userId) may list/read their incoming requests
      allow list, get: if request.auth != null && request.auth.uid == userId;

      // Creating a friend request must be done by the sender and must
      // include their uid as fromUid. This allows an authenticated user to
      // send a request to another user.
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.fromUid
                     && request.resource.data.fromUid == request.auth.uid
                     && request.resource.data.status == 'pending';

      // Allow deletion by recipient (reject/accept) or sender (cancel)
      allow delete: if request.auth != null && (
        request.auth.uid == userId || // recipient can remove
        request.auth.uid == resource.data.fromUid // sender can cancel
      );

      // Disallow client-side updates
      allow update: if false;
    }

    // Friends documents: users/{userId}/friends/{friendUid}
    match /users/{userId}/friends/{friendUid} {
      // Allow read for either side
      allow get, list: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendUid);

      // Allow creation if the caller is either the owner of this doc (userId)
      // or the friend (friendUid). This supports the app writing both
      // directions when accepting a request.
      allow create: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendUid)
                    && request.resource.data.uid == friendUid;

      // Allow deletion by either side
      allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendUid);

      allow update: if false;
    }

    // Outgoing (sent) requests stored under: users/{userId}/sentRequests/{targetUid}
    match /users/{userId}/sentRequests/{targetUid} {
      // Only the owner may list/get their own sent requests
      allow get, list: if request.auth != null && request.auth.uid == userId;

      // Creation only allowed by the owner (sender)
      allow create: if request.auth != null
                     && request.auth.uid == request.resource.data.fromUid
                     && request.resource.data.fromUid == request.auth.uid
                     && request.resource.data.toUid == targetUid
                     && request.resource.data.status == 'pending'
                     && request.resource.data.createdAt is timestamp;

      // Deletion only by the owner (sender)
      allow delete: if request.auth != null && request.auth.uid == userId;

      allow update: if false;
    }

    // User-owned documents: todos, subtasks and stats. Only the user may read/write
    // their own private data. Profiles (users/{userId}) are readable by any
    // authenticated user so the app can show friend display names / avatars.
    match /users/{userId} {
      // allow other authenticated users to read a user's public profile (displayName, photoURL, username)
      allow get: if request.auth != null;

      // TEMPORARY: Allow authenticated clients to list/query the `users`
      // collection. This relaxes previous restrictions to unblock client
      // email-search behavior quickly. IMPORTANT: revert to a stricter
      // rule (e.g., require a single equality on `emailLowerCase`) for
      // production to avoid exposing broad user data.
      allow list: if request.auth != null;

      // todos collection: owner-only access
      match /todos/{todoId} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
  allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.text is string;
        allow update, delete: if request.auth != null && request.auth.uid == userId;

        // subtasks nested under a todo
        match /subtasks/{subId} {
          allow get, list: if request.auth != null && request.auth.uid == userId;
          allow create: if request.auth != null
                        && request.auth.uid == userId
                        && request.resource.data.text is string;
          allow update, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // generalTodos collection: same owner-only access as /todos
      match /generalTodos/{todoId} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.text is string;
        allow update, delete: if request.auth != null && request.auth.uid == userId;

        // subtasks nested under a generalTodo
        match /subtasks/{subId} {
          allow get, list: if request.auth != null && request.auth.uid == userId;
          allow create: if request.auth != null
                        && request.auth.uid == userId
                        && request.resource.data.text is string;
          allow update, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // monthlyTodos collection: owner-only access (mirrors todos/generalTodos)
      match /monthlyTodos/{todoId} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.text is string;
        allow update, delete: if request.auth != null && request.auth.uid == userId;

        // subtasks nested under a monthlyTodo
        match /subtasks/{subId} {
          allow get, list: if request.auth != null && request.auth.uid == userId;
          allow create: if request.auth != null
                        && request.auth.uid == userId
                        && request.resource.data.text is string;
          allow update, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // weeklyTodos collection: owner-only access (mirrors todos/generalTodos)
      match /weeklyTodos/{todoId} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.text is string;
        allow update, delete: if request.auth != null && request.auth.uid == userId;

        // subtasks nested under a weeklyTodo
        match /subtasks/{subId} {
          allow get, list: if request.auth != null && request.auth.uid == userId;
          allow create: if request.auth != null
                        && request.auth.uid == userId
                        && request.resource.data.text is string;
          allow update, delete: if request.auth != null && request.auth.uid == userId;
        }
      }

      // stats documents used by the app (summary, monthlyStats, dailyStats, dailyMeta)
      // allow the owner to read/write their stats; other users should not modify them.
      match /stats/{statDoc} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /monthlyStats/{monthKey} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /dailyStats/{dayKey} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Shared tasks collection: top-level shared tasks that multiple users participate in
    match /shared/{sharedId} {
      // Creation: caller must be authenticated, 'participants' must be a list,
      // the caller must be included in the participants array and must be the creator.
      // permit creation where createdAt may be client timestamp or serverTimestamp() (null in request)
      allow create: if request.auth != null
                    && request.resource.data.participants is list
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.text is string
                    && (
                      request.resource.data.createdAt is timestamp ||
                      request.resource.data.createdAt == null
                    );

      // Read single document only for participants
      allow get: if request.auth != null && request.auth.uid in resource.data.participants;

  // Allow listing shared tasks for authenticated users. Note: this permits
  // the client to perform queries; per-document `get` still enforces
  // participant membership. If you prefer stricter controls, change this
  // to require a query filter (array-contains) and validate request.query.
  allow list: if request.auth != null;

      // Updates: only participants may update. Ensure the creator field is not changed
      // and that the participants array still contains the caller.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    && request.resource.data.createdBy == resource.data.createdBy
                    && request.resource.data.participants is list
                    && request.auth.uid in request.resource.data.participants;

      // Deletion: any participant may delete the shared task (app may restrict further if desired)
      allow delete: if request.auth != null && request.auth.uid in resource.data.participants;

      // Subtasks nested under a shared task: participants may read/write subtasks
      match /subtasks/{subId} {
        function isParticipant() {
          return exists(/databases/$(database)/documents/shared/$(sharedId))
                 && request.auth != null
                 && request.auth.uid in get(/databases/$(database)/documents/shared/$(sharedId)).data.participants;
        }

        allow get, list: if isParticipant();
        // allow create when createdAt is provided or when client used serverTimestamp()
        allow create: if isParticipant() && request.resource.data.text is string && (
                        request.resource.data.createdAt is timestamp || request.resource.data.createdAt == null
                      );
        allow update, delete: if isParticipant();
      }
    }

    // Top-level general tasks: `generalTodos/{todoId}`
    // These are global tasks not scoped under a user document. Each doc must
    // include a `createdBy` field containing the UID of the creator. Clients
    // may list/get when authenticated. Creation requires the client to set
    // `createdBy` to their own UID. Updates/deletes are limited to the owner.
    match /generalTodos/{todoId} {
      allow get, list: if request.auth != null;

      // permit creation with either a client timestamp or serverTimestamp()
      allow create: if request.auth != null
                     && request.resource.data.text is string
                     && request.resource.data.createdBy == request.auth.uid
                     && (
                       request.resource.data.createdAt is timestamp ||
                       request.resource.data.createdAt == null
                     );

      allow update, delete: if request.auth != null
                             && resource.data.createdBy == request.auth.uid
                             && request.resource.data.createdBy == resource.data.createdBy;

      // Subtasks nested under a generalTodo. Only the todo owner may create/update/delete subtasks.
      match /subtasks/{subId} {
        allow get, list: if request.auth != null;
        // allow creation of subtasks if the authenticated user owns the parent
        // todo — accept serverTimestamp() sentinel (will appear as null in request)
        allow create: if request.auth != null
                      && exists(/databases/$(database)/documents/generalTodos/$(todoId))
                      && get(/databases/$(database)/documents/generalTodos/$(todoId)).data.createdBy == request.auth.uid
                      && request.resource.data.text is string
                      && (
                        request.resource.data.createdAt is timestamp ||
                        request.resource.data.createdAt == null
                      );
        allow update, delete: if request.auth != null
                              && exists(/databases/$(database)/documents/generalTodos/$(todoId))
                              && get(/databases/$(database)/documents/generalTodos/$(todoId)).data.createdBy == request.auth.uid;
      }
    }

    // Default: deny everything else. Be explicit about collection rules as
    // your app grows instead of opening up a permissive catch-all.
    // Chat metadata and messages.
    // Chats should contain a small metadata document at `chats/{chatId}`
    // with a `participants` array (e.g. [uid1, uid2]). Rules below ensure
    // only participants can read/write messages.
    match /chats/{chatId} {
  // Allow creating a chat metadata doc if the authenticated user is
  // included in the provided participants array. This lets the client
  // create the chat document before sending the first message.
  allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;

  // Allow reading chat metadata for authenticated users so clients can
  // check existence before creating. This is a small relaxation to
  // enable client-side create-if-missing flows; tighten later if
  // necessary (e.g. to participants-only reads).
  allow get: if request.auth != null;

      // Allow participants to set their own `lastSeen` timestamp via a merge
      // update that only touches the `lastSeen` map. This lets clients record
      // when a participant last opened the chat while preventing changes to
      // other metadata (participants, etc.). Deletions and arbitrary updates
      // remain disallowed.
      allow update: if request.auth != null
                      && exists(/databases/$(database)/documents/chats/$(chatId))
                      // caller must be a participant
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      // update must only contain the `lastSeen` top-level key
                      && request.resource.data.keys().hasOnly(['lastSeen'])
                      // lastSeen must only contain the caller's uid key (so they can't touch others)
                      && request.resource.data.lastSeen.keys().hasOnly([request.auth.uid])
                      // and the caller must set their own lastSeen entry to a timestamp or serverTimestamp() (null sentinel)
                      && (
                        request.resource.data.lastSeen[request.auth.uid] is timestamp ||
                        request.resource.data.lastSeen[request.auth.uid] == null
                      );
          allow delete: if false;

      match /messages/{messageId} {
        // Helper: check that the chat metadata exists and the caller is a participant
        function isParticipant() {
          return exists(/databases/$(database)/documents/chats/$(chatId))
                 && request.auth != null
                 && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }

        // Only participants may read messages for this chat.
        allow get, list: if isParticipant();

        // Creation: caller must be authenticated, must be a participant,
        // fromUid must match caller, toUid must be one of the participants,
        // and either text or mediaUrl must be provided.
        allow create: if isParticipant()
                      && request.resource.data.fromUid == request.auth.uid
                      && request.resource.data.toUid is string
                      && request.resource.data.toUid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && (
                        request.resource.data.text is string ||
                        request.resource.data.mediaUrl is string
                      );

        // Disallow client updates/deletes of existing messages.
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
