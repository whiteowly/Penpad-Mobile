{
  "expo": {
    "name": "PenPad",
    "slug": "penpad-todo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "todolisss",
    "userInterfaceStyle": "automatic",

    "ios": {
      "bundleIdentifier": "com.whiteowly.todolisss"
    },
    "android": {
      "package": "com.jer.todolisss",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpg",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "enableProguardInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.facebook.react.turbomodule.** { *; }"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7765b430-40c4-4756-9e5d-609ce816fef7"
      }
    }
  }
}
